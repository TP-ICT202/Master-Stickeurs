# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
# GEMINI_API_KEY: Google AI Studio (format AQ. ou AIza)
GEMINI_API_KEY=your_gemini_key_here

# IMAGE_GPT_API_KEY: ImageGPT backgrounds (api.imagegpt.org)
IMAGE_GPT_API_KEY=your_imagegpt_key_here

# KILPY_API_KEY: KLIPY GIF API (klipy.com/developers)
KILPY_API_KEY=your_klipy_key_here
