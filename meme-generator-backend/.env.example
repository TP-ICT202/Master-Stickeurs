# ============================================
# CONFIGURATION SERVEUR
# ============================================
PORT=3000

# ============================================
# CLÉ API GOOGLE GEMINI (100% GRATUIT)
# ============================================
# 1. Aller sur https://aistudio.google.com/app/apikey
# 2. Connecter votre compte Google
# 3. Cliquer "Create API key"
# 4. Copier la clé (format : AIzaSy...)
#
# Quota gratuit : 1 500 requêtes/jour — largement suffisant
# Couvre : texte, vision, audio, génération d'image
#
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# CONFIGURATION UPLOADS
# ============================================
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads/
